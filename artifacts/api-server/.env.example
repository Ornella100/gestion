# Port d'écoute du serveur API (optionnel en local, défaut : 8080)
PORT=8080

# Base de données PostgreSQL (uniquement nécessaire quand le vrai DB sera branché)
# DATABASE_URL=postgresql://user:password@localhost:5432/university_db

# Clé secrète pour les sessions (générez une chaîne aléatoire longue)
SESSION_SECRET=remplacez-par-une-cle-secrete-longue

# Niveau de log : trace | debug | info | warn | error
LOG_LEVEL=info
